# FairChain Backend — Environment Variables
# Copy to .env and fill in your values

# Supabase (for writing prediction results to segment_states table)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Gemini API (for AI explainability)
GEMINI_API_KEY=your-gemini-api-key-here

# CORS — additional allowed origins (comma-separated)
# Your Vercel frontend URL goes here
ALLOWED_ORIGINS=https://fairchain.vercel.app
