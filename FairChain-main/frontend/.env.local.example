# Copy this file to .env.local and fill in your values
# .env.local is already in .gitignore — never commit real keys

# Supabase (Task 3 — Realtime hook)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Mapbox (Task 2 — Route Visualizer)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJ...

# Gemini (Task 6 — AI Insight Panel)
# Keep this SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_
GEMINI_API_KEY=your-gemini-key-here

# Backend (FastAPI) base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
